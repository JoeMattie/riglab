    "react-konva": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "24.10.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
